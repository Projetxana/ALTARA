{
    "rewrites": [
        {
            "source": "/api/airbnb/:path*",
            "destination": "https://airbnb13.p.rapidapi.com/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
      ],
  "functions": {
    "api/*.js": {
      "runtime": "nodejs18.x"
    }
  }
}
